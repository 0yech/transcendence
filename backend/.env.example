# Copy this to backend/.env (`cp .env.example .env`) for host-side work:
# `prisma generate` / `prisma studio` and running the backend on the host.
#
# DATABASE_URL uses localhost because the Postgres container publishes 5432 to
# the host. Inside Docker the backend instead reads the root .env-example, where
# DATABASE_URL targets the in-network `database` host. Same variable name, value
# appropriate to where the process runs.
DATABASE_URL=postgresql://transcendence:transcendence@localhost:5432/transcendence?schema=public

JWT_SECRET=transcendence
